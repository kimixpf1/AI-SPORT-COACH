generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Analysis {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  // 动作类型
  exerciseType  String

  // 视频元数据
  videoFileName String?
  videoDuration Float?

  // 分析结果（JSON格式）
  trajectoryData Json?    // 杠铃轨迹数据
  velocityData   Json?    // 速度/加速度数据
  postureAnalysis Json?   // 姿态分析

  // 综合评分和建议
  overallScore  Float?
  suggestions   String?

  // 原始AI响应（用于调试）
  rawResponse   String?

  @@index([createdAt])
}
